[alias]
	# いい感じのグラフでログを表示
	graph = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
	# 上の省略形
	gr = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
	st = status
	#cm = commit
	# Untracked filesを表示せず，not stagedと，stagedだけの状態を出力する
	stt = status -uno
	# 行ごとの差分じゃなくて，単語レベルでの差分を色付きで表示する
	difff = diff --word-diff
	# ステージングしたコードを確認
	diffst = diff --staged
	diffpr = diff main...HEAD
	# add を確認
	add = add -p
	empty = commit --allow-empty -m "empty"
	l = graph
	delete-merged-branch = "!f () { git checkout $1; git branch --merged|egrep -v '\\*|develop|main'|xargs git branch -d; git fetch --prune; };f"
	fetchmerge = "!f () { git fetch; git rev-parse --abbrev-ref HEAD | xargs -I{} git merge origin/{}; };f"
	branchdate = "!f () { git for-each-ref --sort=committerdate refs/heads/ --format='%(committerdate:short) %(refname:short)' | tail -n 8; };f"
	chz = !git branch --sort=-authordate | fzf | xargs git checkout
	hardpull = !git fetch origin && git reset --hard origin/$(git rev-parse --abbrev-ref HEAD)



[user]
	name = Tetsu Takizawa
	email = tetsu.takizawa5@gmail.com
	signingkey = B4A55FE34F95ABC1B12D8E43A58AB3F4102ED7CD
[merge]
	ff = false
[pull]
	ff = only
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[filter "ignoregomodreplace"]
	smudge = cat
    #clean = sed -E 's/^(\\t?)(replace)?( *)(github\\.com\\/(l|L)evetty[-a-zA-Z0-9\\/\\.\\t ]+=>.+)/\\/\\/\\1\\2\\3\\4/g'
	clean = sed -E 's/^(replace)?( *)(github\\.com\\/(l|L)evetty[-a-zA-Z0-9\\/\\.\\t ]+=>.+)/\\/\\/\\1\\2\\3/g'
[secrets]
	providers = git secrets --aws-provider
	patterns = (A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}
	patterns = (\"|')?(AWS|aws|Aws)?_?(SECRET|secret|Secret)?_?(ACCESS|access|Access)?_?(KEY|key|Key)(\"|')?\\s*(:|=>|=)\\s*(\"|')?[A-Za-z0-9/\\+=]{40}(\"|')?
	patterns = (\"|')?(AWS|aws|Aws)?_?(ACCOUNT|account|Account)_?(ID|id|Id)?(\"|')?\\s*(:|=>|=)\\s*(\"|')?[0-9]{4}\\-?[0-9]{4}\\-?[0-9]{4}(\"|')?
	allowed = AKIAIOSFODNN7EXAMPLE
	allowed = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
[init]
    #templatedir = ~/.git-templates/git-secrets
	defaultBranch = main
[push]
	default = current
[credential]
        helper = !aws --profile zucks-affiliate --region us-east-1 codecommit credential-helper $@
        UseHttpPath = true
[commit]
	gpgsign = true
[core]
	editor = vim -c \"set fenc=utf-8\"
	filemode = false
[ghq]
	root = ~/repo
[color]
	ui = auto
#[interactive]
#    diffFilter = delta --color-only
[delta]
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
	line-numbers = true
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
