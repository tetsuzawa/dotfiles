{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:support.claude.com)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          },
          {
            "type": "command",
            "command": "slack-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/taki/.claude/hooks/hook_stop_words.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/taki/.claude/hooks/hook_pre_commands.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "mcp-apps@mcp-apps": false,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "db@cloudbase": true,
    "archaeologist@cloudbase": true,
    "datadog@cloudbase": true,
    "cloudbase-kb@cloudbase": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "scan-data@cloudbase": true,
    "aws-remediate-docgen@cloudbase": true
  },
  "extraKnownMarketplaces": {
    "cloudbase": {
      "source": {
        "source": "github",
        "repo": "Levetty/claude-code"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "additionalDirectories": [
    "/Users/taki/repo/ws/nippo"
  ],
  "feedbackSurveyState": {
    "lastShownTime": 1754385656477
  },
  "voiceEnabled": true
}
